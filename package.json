{
  "name": "@ismaelmartinez/generator-atlassian-compass-event-catalog",
  "version": "0.4.0",
  "description": "Atlassian Compass generator for Event Catalog",
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:diff": "prettier --list-different .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "atlassian",
    "compass",
    "EventCatalog",
    "generator"
  ],
  "author": "ismaelmartinez@gmail.com",
  "packageManager": "pnpm@9.15.9",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@eventcatalog/sdk": "^2.19.0",
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  }
}
